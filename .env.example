# Your Plane / Nirmaan instance
PLANE_BASE_URL=https://nirmaan.credresolve.com

# Generate in Nirmaan: Workspace Settings → API Tokens
PLANE_API_KEY=plane_api_replace_me

# Workspace slug from your URL: nirmaan.credresolve.com/<slug>/...
PLANE_WORKSPACE_SLUG=cr-product

# Project ID — leave blank for first run.
# After running smoke_test.py, copy the ID for your project here.
PLANE_PROJECT_ID=

# Optional: module ID inside that project, e.g. AgentX inside Builder.
# After PLANE_PROJECT_ID is set, smoke_test.py lists modules and their IDs.
PLANE_MODULE_ID=

# Optional: your user ID, useful later for "issues assigned to me" filters
PLANE_USER_ID=

# AgentX module UUID — every ticket the bot creates gets attached to this module
PLANE_DEFAULT_MODULE_ID=

# Tech label UUID (comma-separated if you want multiple)
PLANE_DEFAULT_LABEL_IDS=

# Default estimate as a Plane integer (depends on your project's scale; M is often 2)
PLANE_DEFAULT_ESTIMATE=2

# Default priority — none / low / medium / high / urgent
PLANE_DEFAULT_PRIORITY=none